{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Voxly",
  "version": "1.0.0",
  "identifier": "com.voxly.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Voxly",
        "width": 900,
        "height": 620,
        "minWidth": 820,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "center": true,
        "titleBarStyle": "Visible"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data: https://asset.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "public.app-category.productivity",
    "copyright": "Copyright 2026 Voxly. All rights reserved.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0",
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true,
      "exceptionDomain": ""
    }
  },
  "plugins": {}
}
